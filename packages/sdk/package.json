{
  "name": "@tfjs/sdk",
  "version": "0.1.0",
  "description": "TypeScript-native Terraform provider plugin framework (tfplugin6 / Protocol v6)",
  "files": [
    "dist/",
    "proto/"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "proto:gen": "node scripts/gen-proto.js",
    "build": "pnpm run proto:gen && tsc",
    "dev": "tsc --watch",
    "test": "node --require tsx/cjs --test 'src/*.test.ts'"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0",
    "@msgpack/msgpack": "3.1.3",
    "long": "5.3.2",
    "nice-grpc": "2.1.15",
    "nice-grpc-common": "2.0.3",
    "selfsigned": "5.5.0",
    "ts-proto": "2.11.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "grpc-tools": "1.13.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
