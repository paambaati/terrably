{
  "name": "terrably",
  "version": "0.0.1",
  "description": "TypeScript-native Terraform provider authoring framework",
  "author": {
    "name": "GP",
    "email": "me@httgp.com",
    "url": "https://httgp.com"
  },
  "files": [
    "dist/",
    "proto/"
  ],
  "type": "commonjs",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js"
    }
  },
  "scripts": {
    "proto:gen": "node scripts/gen-proto.js",
    "build": "pnpm run proto:gen && tsc && cp -r src/cli/templates dist/src/cli/",
    "dev": "tsc --watch",
    "lint": "oxlint --type-aware --type-check src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt src/",
    "test": "node --require tsx/cjs --test 'src/*.test.ts'",
    "prepublishOnly": "pnpm run build && pnpm run lint && pnpm run test"
  },
  "bin": {
    "terrably": "dist/src/cli/index.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0",
    "@msgpack/msgpack": "3.1.3",
    "adm-zip": "0.5.17",
    "cac": "7.0.0",
    "esbuild": "0.28.0",
    "long": "5.3.2",
    "nice-grpc": "2.1.15",
    "nice-grpc-common": "2.0.3",
    "nunjucks": "3.2.4",
    "pino": "10.3.1",
    "selfsigned": "5.5.0",
    "ts-proto": "2.11.6"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.8",
    "@types/node": "25.6.0",
    "@types/nunjucks": "3.2.6",
    "grpc-tools": "1.13.1",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
