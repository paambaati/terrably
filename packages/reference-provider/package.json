{
  "name": "terrably-reference-provider",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "build:binary": "terrably build --name dummycloud",
    "postbuild:binary": "node -e \"const fs=require('fs'),path=require('path'),r=process.cwd();const tpl=fs.readFileSync(path.join(r,'tf-workspace','.terraformrc.tpl'),'utf8');fs.writeFileSync(path.join(r,'tf-workspace','.terraformrc'),tpl.replace('__BIN_DIR__',path.join(r,'bin')));\"",
    "pretest": "node scripts/ensure-binary.mjs",
    "start": "node --require tsx/cjs src/main.ts",
    "api": "node --require tsx/cjs api-server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --require tsx/cjs --test tests/e2e.test.ts"
  },
  "dependencies": {
    "terrably": "workspace:*",
    "@hono/node-server": "2.0.0",
    "hono": "4.12.14"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
