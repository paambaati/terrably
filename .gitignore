dist/
node_modules/
.DS_Store

# TypeScript source maps, declaration maps & incremental build artifacts
*.js.map
*.d.ts.map
tsconfig.tsbuildinfo

# Compiled provider binaries (SEA)
packages/reference-provider/bin-sea/
packages/reference-provider/bin/terraform-provider-*

# Generated Terraform dev config (contains machine-specific absolute path)
packages/reference-provider/tf-workspace/.terraformrc

# SEA build intermediates
packages/*/dist/_sea_bundle.cjs
packages/*/dist/_sea_entry.cjs
packages/*/dist/sea-config.json

# Terraform state, plans, and lock files
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/tfplan
**/.terraform.lock.hcl

# Temporary files from E2E tests and SEA builds
/tmp/tf-js-proto-*/
/tmp/tf-e2e-*/
/tmp/terraformrc-*/

# Fumadocs / Next.js docs site
packages/docs/.next/
packages/docs/.source/
packages/docs/out/
