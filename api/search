url":"/docs/reference/logging#child-loggers--subsystems","content":"Attach request-scoped context:"},"499":{"id":"/docs/reference/serve","page_id":"/docs/reference/serve","type":"page","content":"serve()","breadcrumbs":["terrably","Reference"],"tags":[],"url":"/docs/reference/serve"},"500":{"id":"/docs/reference/serve-0","page_id":"/docs/reference/serve","tags":[],"type":"text","url":"/docs/reference/serve","content":"Start the gRPC server and perform the go-plugin handshake — the entry point for every terrably provider."},"501":{"id":"/docs/reference/serve-1","page_id":"/docs/reference/serve","type":"heading","tags":[],"url":"/docs/reference/serve#signature","content":"Signature"},"502":{"id":"/docs/reference/serve-2","page_id":"/docs/reference/serve","type":"heading","tags":[],"url":"/docs/reference/serve#serveoptions","content":"`ServeOptions`"},"503":{"id":"/docs/reference/serve-3","page_id":"/docs/reference/serve","type":"heading","tags":[],"url":"/docs/reference/serve#normal-mode","content":"Normal mode"},"504":{"id":"/docs/reference/serve-4","page_id":"/docs/reference/serve","type":"heading","tags":[],"url":"/docs/reference/serve#dev-mode","content":"Dev mode"},"505":{"id":"/docs/reference/serve-5","page_id":"/docs/reference/serve","type":"heading","tags":[],"url":"/docs/reference/serve#environment-variables","content":"Environment variables"},"506":{"id":"/docs/reference/serve-6","page_id":"/docs/reference/serve","tags":[],"type":"text","url":"/docs/reference/serve#serveoptions","content":"<TypeTable\n  type=\"{\n  socketPath: {\n    description: &#x22;Unix socket path to listen on. Defaults to an auto-generated path under `os.tmpdir()`.&#x22;,\n    type: &#x22;string&#x22;,\n  },\n  dev: {\n    description: &#x22;Dev mode: use an insecure socket and print the `TF_REATTACH_PROVIDERS` export instead of the handshake line. Equivalent to `TF_PLUGIN_DEBUG=1`.&#x22;,\n    type: &#x22;boolean&#x22;,\n    default: &#x22;false&#x22;,\n  },\n  protoDir: {\n    descri