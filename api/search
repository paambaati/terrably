s/schema-6","page_id":"/docs/concepts/schema","type":"heading","tags":[],"url":"/docs/concepts/schema#schema","content":"Schema"},"127":{"id":"/docs/concepts/schema-7","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#types","content":"Every attribute in a schema requires a `TfType`. Types are created via the `types` factory — each call returns a fresh instance."},"128":{"id":"/docs/concepts/schema-8","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#types","content":"<TypeTable\n  type=\"{\n  &#x22;types.string()&#x22;: {\n    description: &#x22;Terraform `string`. TypeScript: `string`.&#x22;,\n    type: &#x22;TfType<string>&#x22;,\n  },\n  &#x22;types.number()&#x22;: {\n    description: &#x22;Terraform `number`. TypeScript: `number`.&#x22;,\n    type: &#x22;TfType<number>&#x22;,\n  },\n  &#x22;types.bool()&#x22;: {\n    description: &#x22;Terraform `bool`. TypeScript: `boolean`.&#x22;,\n    type: &#x22;TfType<boolean>&#x22;,\n  },\n  &#x22;types.normalizedJson()&#x22;: {\n    description: &#x22;Terraform `string` (JSON round-tripped with sorted keys). TypeScript: `unknown`. Prevents spurious diffs from key reordering.&#x22;,\n    type: &#x22;TfType<unknown>&#x22;,\n  },\n  &#x22;types.list(T)&#x22;: {\n    description: &#x22;Terraform `list(T)`. TypeScript: `T[]`.&#x22;,\n    type: &#x22;TfType<T[]>&#x22;,\n  },\n  &#x22;types.set(T)&#x22;: {\n    description: &#x22;Terraform `set(T)`. TypeScript: `T[]`.&#x22;,\n    type: &#x22;TfType<T[]>&#x22;,\n  },\n  &#x22;types.map(T)&#x22;: {\n    description: &#x22;Terraform `map(T)`. TypeScript: `Record<string, T>`.&#x22;,\n    type: &#x22;TfType<Record<string, T>>&#x22;,\n  },\n}\"\n/>"},"129":{"id":"/docs/concepts/schema-9","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#types","content":"**Composing types**"},"130":{"id":"/docs/concepts/schema-10","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#custom-tftypet","content":"Implement this interface to define a custom type –"},"131":{"id":"/docs/concepts/schema-11","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#attribute","content":"Describes a single field in a resource or provider schema."},"132":{"id":"/docs/concepts/schema-12","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#attributeoptions","content":"<TypeTable\n  type=\"{\n  required: {\n    description: &#x22;User must provide this attribute in their config.&#x22;,\n    type: &#x22;boolean&#x22;,\n    default: &#x22;false&#x22;,\n  },\n  optional: {\n    description: &#x22;User may provide this attribute.&#x22;,\n    type: &#x22;boolean&#x22;,\n    default: &#x22;false&#x22;,\n  },\n  computed: {\n    description: &#x22;Provider computes this value. Cannot be set by the user unless also `optional`.&#x22;,\n    type: &#x22;boolean&#x22;,\n    default: &#x22;false&#x22;,\n  },\n  sensitive: {\n    description: &#x22;Value is redacted in plan output and stored encrypted in state. See [sensitive data in state](https://developer.hashicorp.com/terraform/language/state/sensitive-data).&#x22;,\n    type: &#x22;boolean&#x22;,\n    default: &#x22;false&#x22;,\n  },\n  requiresReplace: {\n    description: &#x22;Changing this attribute [destroys and recreates the resource](https://developer.hashicorp.com/terraform/plugin/framework/resources/plan-modification#requiresreplace).&#x22;,\n    type: &#x22;boolean&#x22;,\n    default: &#x22;false&#x22;,\n  },\n  description: {\n    description: &#x22;Shown in `terraform providers schema`.&#x22;,\n    type: &#x22;string&#x22;,\n    default: '&#x22;&#x22;',\n  },\n  descriptionKind: {\n    description: &#x22;Format of the description.&#x22;,\n    type: '&#x22;plain&#x22; | &#x22;markdown&#x22;',\n    default: '&#x22;markdown&#x22;',\n  },\n  deprecated: {\n    description: &#x22;Shows a deprecation warning when the attribute is used.&#x22;,\n    type: &#x22;boolean&#x22;,\n    default: &#x22;false&#x22;,\n  },\n  deprecationMessage: {\n    description: &#x22;Custom deprecation text.&#x22;,\n    type: &#x22;string&#x22;,\n    default: '&#x22;&#x22;',\n  },\n  default: {\n    description: &#x22;Default value used during planning when the attribute is not set.&#x22;,\n    type: &#x22;unknown&#x22;,\n    default: &#x22;undefined&#x22;,\n  },\n}\"\n/>"},"133":{"id":"/docs/concepts/schema-13","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#attributeoptions","content":"**Common patterns**"},"134":{"id":"/docs/concepts/schema-14","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#attributeoptions","content":"`optional: true, computed: true` together means \"user can set it, or the provider will compute a default\". This is useful for auto-assigned values like `name` or `region` that the user might want to control."},"135":{"id":"/docs/concepts/schema-15","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#nestedblock","content":"Represents a block that can appear zero or more times (e.g. `network_interface`, `tags`)."},"136":{"id":"/docs/concepts/schema-16","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#nestedblock","content":"`NestMode`"},"137":{"id":"/docs/concepts/schema-17","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#nestedblock","content":"Terraform equivalent"},"138":{"id":"/docs/concepts/schema-18","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#nestedblock","content":"TypeScript shape"},"139":{"id":"/docs/concepts/schema-19","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/docs/concepts/schema#nestedblock","content":"`\"single\"`"},"140":{"id":"/docs/concepts/schema-20","page_id":"/docs/concepts/schema","tags":[],"type":"text","url":"/d